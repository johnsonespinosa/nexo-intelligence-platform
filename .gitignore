# ============================================
# Nexo Intelligence Platform - .gitignore
# ============================================

# IDEs
.vscode/
.idea/
*.sln.iml
*.user

# .NET
src/backend/**/bin/
src/backend/**/obj/
src/backend/**/TestResults/
*.db
*.db-shm
*.db-wal

# Python
src/ai-layer/__pycache__/
src/ai-layer/.pytest_cache/
src/ai-layer/.coverage
src/ai-layer/htmlcov/
src/ai-layer/.venv/
src/ai-layer/venv/
src/ai-layer/*.pyc
src/ai-layer/.mypy_cache/

# Environment
.env
.env.local
.env.*.local
*.secrets

# Docker
**/Dockerfile.dockerignore
*.log

# Infrastructure
infra/docker/.env
*.pid

# OS
.DS_Store
Thumbs.db

# Secrets (nunca commitear)
**/secrets/
**/*.key
**/*.pem
**/cert.pfx

# Build artifacts
dist/
build/
*.nupkg

# Testing
coverage/
*.trx
*.coverage

# Temporary files
*.tmp
*.temp
*.cache